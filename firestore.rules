rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================
    // USERS COLLECTION
    // ============================================
    match /Users/{userId} {
      allow get: if request.auth != null;
      allow list: if true;
      allow create: if request.auth != null &&
                       request.resource.data.uid == request.auth.uid &&
                       request.resource.data.role == 'Employee';
      allow update: if request.auth != null &&
                       (
                         (resource.data.uid == request.auth.uid &&
                          request.resource.data.role == resource.data.role) ||
                         request.auth != null
                       );
      allow delete: if request.auth != null;
    }

    // ============================================
    // COMPANY POLICIES COLLECTION (NEW)
    // ============================================
    match /CompanyPolicies/{policyId} {
      // Anyone authenticated can read active policies
      allow read: if request.auth != null && resource.data.isActive == true;

      // Only HR/Admin can create policies
      allow create: if request.auth != null;

      // Only HR/Admin can update policies
      allow update: if request.auth != null;

      // Only HR/Admin can delete policies
      allow delete: if request.auth != null;
    }

    // ============================================
    // POLICY STATUS COLLECTION (NEW)
    // ============================================
    match /PolicyStatus/{employeeId} {
      // Employees can read their own policy status
      allow get: if request.auth != null;

      // Employees can read list of policy statuses
      allow list: if request.auth != null;

      // Employees can create their own policy status document
      allow create: if request.auth != null;

      // Employees can update their own policy status (track opens/acceptances)
      allow update: if request.auth != null;

      // Only HR/Admin can delete policy status documents
      allow delete: if request.auth != null;
    }

    // ============================================
    // LEAVE DATA COLLECTION (NEW)
    // ============================================
    match /LeaveData/{employeeUid} {
      // Employees can read their own leave data
      allow get, list: if request.auth != null && request.auth.uid == employeeUid;

      // Employees can create their own leave balance document
      allow create: if request.auth != null && request.auth.uid == employeeUid;

      // Employees can update their own leave balance (e.g., HR updates later)
      allow update: if request.auth != null && request.auth.uid == employeeUid;

      // Sub-collection for individual leave applications
      match /Applications/{applicationId} {
        allow read: if request.auth != null && request.auth.uid == employeeUid;
        allow create: if request.auth != null && request.auth.uid == employeeUid;
        allow update, delete: if request.auth != null && request.auth.uid == employeeUid;
      }
    }

    // ============================================
    // EMPLOYEE DETAILS COLLECTION
    // Draft and fully-submitted onboarding records both
    // live here — the `status` field distinguishes them,
    // not the collection. (There used to be a separate
    // `Draft` collection; it was consolidated into this
    // one — see CLAUDE.md.)
    // ============================================
    match /EmployeeDetails/{employeeId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
      match /DailyHours/{dateKey} {
        allow read: if request.auth != null;
        allow create, update: if request.auth != null;
        allow delete: if request.auth != null;
      }
    }

    // ============================================
    // Other existing collections...
    // (Supervisors, Departments, etc. - kept as is)
    // ============================================
    match /Supervisors/{supervisorId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null &&
                       request.resource.data.keys().hasAll(['fullname', 'email', 'department', 'uid']);
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    match /Departments/{departmentId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null &&
                       request.resource.data.keys().hasAll(['name', 'members']);
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    match /HoursForwarded/{forwardId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    match /Recruitees/{recruiteeId} {
      allow create: if request.resource.data.keys().hasAll(['fullName', 'email', 'cvUrl', 'submittedAt', 'status'])
                   && request.resource.data.fullName is string
                   && request.resource.data.email is string
                   && request.resource.data.email.matches('.*@.*[.].*')
                   && request.resource.data.cvUrl is string
                   && request.resource.data.status == 'pending';
      allow read: if true;
      allow update: if request.auth != null ||
                       (
                         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'reviewedAt', 'reviewNotes', 'updatedAt'])
                       );
      allow delete: if true;
    }

    match /EmployeeOnboarding/{onboardingId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // ============================================
    // PAYROLL COLLECTIONS (NEW)
    // Managed by HR via lib/screens/hr/Payroll/.
    // Follows the same broad request.auth != null
    // convention already used throughout this file —
    // role gating (HR/Admin write, Accountant/Employee
    // read-only) is enforced at the app layer, same as
    // CompanyPolicies/LeaveData above.
    // ============================================
    match /PayrollSettings/{settingsId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /PayrollRuns/{runId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /PayrollRecords/{recordId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
