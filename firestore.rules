rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ============================================
    // USERS COLLECTION
    // ============================================
    match /Users/{userId} {
      allow get: if request.auth != null;
      allow list: if true;

      allow create: if request.auth != null &&
                       request.resource.data.uid == request.auth.uid &&
                       request.resource.data.role == 'Employee';

      allow update: if request.auth != null &&
                       (
                         (resource.data.uid == request.auth.uid &&
                          request.resource.data.role == resource.data.role) ||
                         request.auth != null
                       );

      allow delete: if request.auth != null;
    }
    
    // ============================================
    // DRAFT COLLECTION
    // ============================================
    match /Draft/{draftId} {
      allow read: if request.auth != null;

      //    Auth presence is the correct and sufficient guard here.
      allow create: if request.auth != null;

      allow update: if request.auth != null &&
                       (
                         resource.data.uid == request.auth.uid ||
                         request.auth != null
                       );

      //    delete — covers both HR dashboard deletes AND the firestore_service
      //    draft-cleanup that runs during submission (status draft → submitted).
      allow delete: if request.auth != null;

      match /DailyHours/{dateKey} {
        allow read: if request.auth != null;
        allow create, update: if request.auth != null;
        allow delete: if request.auth != null;
      }
    }
    
    // ============================================
    // EMPLOYEE DETAILS COLLECTION
    // ============================================
    match /EmployeeDetails/{employeeId} {
      allow read: if request.auth != null;

      //    Auth presence is the correct and sufficient guard here.
      allow create: if request.auth != null;

      allow update: if request.auth != null;
      allow delete: if request.auth != null;

      match /DailyHours/{dateKey} {
        allow read: if request.auth != null;
        allow create, update: if request.auth != null;
        allow delete: if request.auth != null;
      }
    }
    
    // ============================================
    // SUPERVISORS COLLECTION - Supervisor Role Assignments
    // ============================================
    match /Supervisors/{supervisorId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null &&
                       request.resource.data.keys().hasAll(['fullname', 'email', 'department', 'uid']);
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }
    
    // ============================================
    // DEPARTMENTS COLLECTION - Department Management
    // ============================================
    match /Departments/{departmentId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null &&
                       request.resource.data.keys().hasAll(['name', 'members']);
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }
    
    // ============================================
    // HOURS FORWARDED COLLECTION - Supervisor to Accountant
    // ============================================
    match /HoursForwarded/{forwardId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }
    
    // ============================================
    // RECRUITEES COLLECTION - Public recruitment submissions
    // ============================================
    match /Recruitees/{recruiteeId} {
      // ✅ Allow anyone to create (no authentication required for initial submission)
      allow create: if request.resource.data.keys().hasAll(['fullName', 'email', 'cvUrl', 'submittedAt', 'status']) 
                    && request.resource.data.fullName is string
                    && request.resource.data.email is string
                    && request.resource.data.email.matches('.*@.*[.].*')
                    && request.resource.data.cvUrl is string
                    && request.resource.data.status == 'pending';
      
      // ✅ Allow public read access for applicants to check their own status
      // The recruiteeId is the sanitized email, so applicants can read their own document
      allow read: if true;
      
      // ✅ Allow authenticated users (HR/Admin) to update status and review notes
      // Also allow applicants to update their own document (for deletion request)
      allow update: if request.auth != null || 
                       (
                         // Allow status field updates for workflow
                         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'reviewedAt', 'reviewNotes', 'updatedAt'])
                       );
      
      // ✅ Allow deletion by authenticated users OR by the document itself (self-deletion)
      // This enables applicants to delete their own applications
      allow delete: if true;
    }
  }
}