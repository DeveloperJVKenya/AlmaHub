rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ============================================
    // EMPLOYEE DOCUMENTS
    // Uploaded by the onboarding wizard under:
    //   employee_documents/{employeeName}/{fieldName}/{filename}
    // ============================================
    match /employee_documents/{employeeName}/{fieldName}/{filename} {
      // Authenticated users (HR) can read and list all employee documents
      allow read, list: if request.auth != null;

      // Any authenticated user may upload; enforce size + type constraints
      allow create: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024
        && (
          request.resource.contentType.matches('application/pdf') ||
          request.resource.contentType.matches('image/.*') ||
          request.resource.contentType.matches('application/msword') ||
          request.resource.contentType.matches('application/vnd.openxmlformats-officedocument.*')
        );

      // Allow replacing an existing file (re-upload)
      allow update: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024;

      // HR can delete documents
      allow delete: if request.auth != null;
    }

    // Allow listAll() to traverse intermediate prefix paths
    match /employee_documents/{employeeName}/{fieldName} {
      allow list: if request.auth != null;
    }
    match /employee_documents/{employeeName} {
      allow list: if request.auth != null;
    }
    match /employee_documents {
      allow list: if request.auth != null;
    }

    // ============================================
    // COMPANY POLICIES (NEW)
    // Uploaded by HR under:
    //   company_policies/{filename}
    // ============================================
    match /company_policies/{filename} {
      // Authenticated users can read policy documents
      allow read: if request.auth != null;

      // Only authenticated users (HR/Admin) can upload policy documents
      allow create: if request.auth != null
        && request.resource.size < 20 * 1024 * 1024
        && (
          request.resource.contentType.matches('application/pdf') ||
          request.resource.contentType.matches('application/msword') ||
          request.resource.contentType.matches('application/vnd.openxmlformats-officedocument.wordprocessingml.document') ||
          request.resource.contentType.matches('text/plain') ||
          request.resource.contentType.matches('application/vnd.openxmlformats-officedocument.spreadsheetml.sheet') ||
          request.resource.contentType.matches('application/vnd.openxmlformats-officedocument.presentationml.presentation') ||
          request.resource.contentType.matches('application/vnd.ms-excel') ||
          request.resource.contentType.matches('application/vnd.ms-powerpoint')
        );

      // Allow updating existing policy files
      allow update: if request.auth != null
        && request.resource.size < 20 * 1024 * 1024;

      // Only HR/Admin can delete policy files
      allow delete: if request.auth != null;
    }

    // Allow listAll() to traverse company_policies path
    match /company_policies {
      allow list: if request.auth != null;
    }

    // ============================================
    // RECRUITEES FOLDER
    // CV uploads by unauthenticated applicants
    // ============================================
    match /Recruitees/{fileName} {
      // Public upload — applicants are not signed in
      allow write: if request.resource.size < 10 * 1024 * 1024
        && (
          request.resource.contentType.matches('application/pdf') ||
          request.resource.contentType.matches('application/msword') ||
          request.resource.contentType.matches('application/vnd.openxmlformats-officedocument.wordprocessingml.document')
        );

      // Public read so HR and applicants can access the CV URL
      allow read: if true;

      // Allow deletion (HR cleanup or applicant self-deletion)
      allow delete: if true;
    }

    // ============================================
    // PAYROLL PAYSLIPS (NEW)
    // Generated by HR via lib/screens/hr/Payroll/, under:
    //   payroll_payslips/{runId}/{employeeUid}.pdf
    // ============================================
    match /payroll_payslips/{runId}/{filename} {
      // Authenticated users can read payslips (app layer restricts an
      // employee's own view to their own record's payslipUrl).
      allow read: if request.auth != null;

      // Only authenticated users (HR) generate payslips.
      allow create, update: if request.auth != null
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('application/pdf');

      allow delete: if request.auth != null;
    }

    // Allow listAll() to traverse payroll_payslips paths
    match /payroll_payslips/{runId} {
      allow list: if request.auth != null;
    }
    match /payroll_payslips {
      allow list: if request.auth != null;
    }

    // ============================================
    // PROFILE PHOTOS
    // ============================================
    match /profile_photos/{userId} {
      // Users can read any profile photo
      allow read: if request.auth != null;

      // Users can only upload their own profile photo
      allow create, update: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');

      // Users can delete their own profile photo
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // ============================================
    // Default: deny everything else
    // ============================================
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
