# Build output / generated artifacts — never source of truth, regenerated by `flutter build`/`pub get`.
build/
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
*.g.dart
*.freezed.dart

# Platform scaffolding: mostly generated boilerplate/ephemeral files, not hand-edited feature code.
android/.gradle/
android/app/build/
android/gradle/
android/gradlew
android/gradlew.bat
android/local.properties
ios/Pods/
ios/Flutter/Flutter.podspec
ios/Flutter/ephemeral/
ios/.symlinks/
macos/Flutter/ephemeral/
macos/Pods/
linux/flutter/ephemeral/
windows/flutter/ephemeral/
web/.dart_tool/

# IDE/editor project files.
.idea/
.vscode/
*.iml

# Logs, temp, and OS files.
*.log
flutter_01.log
.DS_Store
Thumbs.db

# Version control internals.
.git/

# Large lockfile — dependency versions, not code Claude needs to read to make changes.
pubspec.lock

# One-off Node.js scripts' installed dependencies — not app source.
scripts/**/node_modules/
